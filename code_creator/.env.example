# ─── Jira ────────────────────────────────────────────────────────────────────
# Base URL of your Atlassian instance (no trailing slash)
JIRA_BASE_URL=https://your-org.atlassian.net

# Your Atlassian account email
JIRA_EMAIL=you@example.com

# API token — generate at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# ─── Databricks (dev workspace) ──────────────────────────────────────────────
# Workspace URL — copy from your browser, e.g. https://adb-1234567890.azuredatabricks.net
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net

# SQL warehouse HTTP path — found in Databricks UI under SQL Warehouses > your warehouse > Connection Details
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id

# Personal access token — generate in Databricks UI under User Settings > Developer > Access Tokens
DATABRICKS_ACCESS_TOKEN=

# ─── GitHub ───────────────────────────────────────────────────────────────────
# Personal access token or fine-grained token with Contents + Pull requests write scope
# Generate at https://github.com/settings/tokens
GITHUB_TOKEN=

# GitHub repo in org/repo format
GITHUB_REPO=moodysanalytics/kyc-data-pipelines

# Branch to create feature branches from
GITHUB_BASE_BRANCH=dev

